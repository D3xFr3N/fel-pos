# Modo FEL: disabled (solo ticket POS) | demo | production
FEL_MODE=demo
# Perfil del negocio: abarrotes | farmacia | libreria | ferreteria | restaurante | boutique
BUSINESS_PROFILE=abarrotes
SECURITY_SECRET=CAMBIA_ESTE_SECRETO
ACCESS_TOKEN_MINUTES=720

# Datos persistentes (NO borrar al actualizar)
# Base de datos y respaldos viven en ./data
DATABASE_URL=sqlite:///./data/fel_pos.db
BACKUP_DIR=./data/backups
# Opcional: carpeta personalizada de datos
# FELPOS_DATA_DIR=./data

# Datos del emisor (tu empresa)
EMISOR_NIT=12345678
EMISOR_NOMBRE=Mi Empresa S.A.
EMISOR_NOMBRE_COMERCIAL=Mi Tienda
EMISOR_DIRECCION=Ciudad de Guatemala
EMISOR_CODIGO_POSTAL=01001
EMISOR_MUNICIPIO=Guatemala
EMISOR_DEPARTAMENTO=Guatemala
EMISOR_PAIS=GT
EMISOR_AFILIACION_IVA=GEN
EMISOR_ESTABLECIMIENTO=1

# Certificador (Infile, Digifact, etc.) — solo en modo produccion
CERTIFICADOR=infile
CERTIFICADOR_USUARIO=
CERTIFICADOR_LLAVE=
CERTIFICADOR_URL=https://certificador.infile.com/api

# Gmail (opcional, para enviar ordenes por correo)
GMAIL_SENDER=
GMAIL_APP_PASSWORD=
GMAIL_SMTP_HOST=smtp.gmail.com
GMAIL_SMTP_PORT=587

# WhatsApp API Cloud (opcional, para envio real)
WHATSAPP_PHONE_ID=
WHATSAPP_TOKEN=
WHATSAPP_API_URL=https://graph.facebook.com/v20.0

# Consulta automatica de NIT (opcional)
# Ejemplo de uso: NIT_LOOKUP_URL=https://tu-proveedor/api/nit
# El sistema consultara: {NIT_LOOKUP_URL}/{NIT}
NIT_LOOKUP_URL=
NIT_LOOKUP_TOKEN=
NIT_LOOKUP_TIMEOUT_SECONDS=8

# Impresion ticket (Windows + impresora termica ESC/POS)
# Si RECEIPT_PRINTER_NAME va vacio, usa la impresora predeterminada de Windows.
RECEIPT_PRINTER_NAME=
RECEIPT_PRINT_ON_CHECKOUT=true
RECEIPT_OPEN_DRAWER_ON_CHECKOUT=true
RECEIPT_CHARS_PER_LINE=48
RECEIPT_ENCODING=cp850

# Impresion de etiquetas (codigo de barras)
# Si LABEL_PRINTER_NAME va vacio, usa RECEIPT_PRINTER_NAME o impresora predeterminada.
LABEL_PRINTER_NAME=
LABEL_DEFAULT_WIDTH_MM=50
LABEL_DEFAULT_HEIGHT_MM=30
LABEL_ENCODING=cp850

# Respaldos de base de datos SQLite
BACKUP_DIR=./data/backups
BACKUP_AUTO_DAILY=true
BACKUP_RETENTION_DAYS=30
BACKUP_AUTO_ON_COMMIT=true
BACKUP_AUTO_MIN_INTERVAL_SECONDS=60

# Actualizaciones automaticas (publica dist/release/latest.json en tu servidor o GitHub Pages)
# Servidor propio: UPDATE_MANIFEST_URL=https://tu-dominio.com/fel-pos/latest.json
# GitHub Pages:    UPDATE_MANIFEST_URL=https://D3xFr3N.github.io/fel-pos/latest.json
UPDATE_MANIFEST_URL=
